# IDCSystem production environment template
# Required in production: APP_KEY, APP_URL, database, Redis, mail sender, payment gateway keys.

APP_NAME=IDCSystem
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=zh_CN
APP_FAKER_LOCALE=zh_CN

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Required: production database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=idcsystem
DB_USERNAME=idcsystem
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis
CACHE_PREFIX=idcsystem_cache_

# Required: Redis for cache, session and queues
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
HORIZON_PREFIX=horizon:

# Billing
BILLING_TAX_RATE=0
BILLING_DUE_DAYS=7
BILLING_REMINDER_DAYS=7
BILLING_GRACE_DAYS=0
BILLING_INVOICE_DAYS_BEFORE_DUE=7

# Affiliate
AFFILIATE_COMMISSION_RATE=10
AFFILIATE_COMMISSION_TYPE=payment

# Required: mail delivery
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@your-domain.com
MAIL_FROM_NAME="${APP_NAME}"

# Optional: object storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Frontend build
VITE_APP_NAME="${APP_NAME}"

# Optional: payment plugin credentials should be configured in admin settings
# or plugin-specific encrypted configuration, not committed to source control.
